{
  "manifest_version": 3,
  "name": "ContentCal — Creator Content Calendar",
  "version": "1.0.0",
  "description": "Plan, schedule, and track your content across YouTube, X, LinkedIn, and Instagram — all locally, zero cloud.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "sidePanel",
    "alarms"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_page": "fullpage.html",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  }
}
